<!DOCTYPE html>
<html lang="en">

<head>
  <!-- Basic page metadata and responsive settings -->
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- Page title is dynamically set from each route -->
  <title>
    <%= title %>
  </title>

  <!-- Favicon and styles -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/stylesheets/style.css" />
</head>

<body class="d-flex flex-column min-vh-100">

  <!-- Global navigation bar shared across all pages -->
  <header>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <a class="navbar-brand" href="/">RiftTracker</a>

        <!-- Mobile toggle button for collapsing navbar -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
          aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Navigation links to main app pages -->
        <div class="collapse navbar-collapse" id="mainNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item">
              <a class="nav-link" href="/">Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/matches">Matches</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/matches/new">Add Match</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/stats">Stats</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>
  </header>

  <!-- Main content area where each page's EJS view is injected -->
  <main class="flex-grow-1 position-relative">
    <%- body %>
  </main>

  <!-- Footer displayed on all pages -->
  <footer class="border-top rt-footer">
    <div class="container py-2 text-center small">
      <strong>RiftTracker</strong> •
      © <span id="year"></span> Chase Stombaugh •
      CS408 Full Stack Web Development •
      Not affiliated with Riot Games
    </div>
  </footer>

  <!-- Bootstrap JS bundle for UI components (navbar toggle, etc.) -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

  <!-- Dynamically sets the current year in the footer -->
  <script>
    document.getElementById('year').textContent = new Date().getFullYear();
  </script>

  <!-- Custom JavaScript for additional client-side behavior -->
  <script src="/javascripts/myscript.js"></script>
</body>

</html>