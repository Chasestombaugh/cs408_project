<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-10 col-xl-8">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h1 class="mb-1 text-gold">
            <%= title %>
          </h1>
          <p class="text-light opacity-75 mb-0">
            Log a new match with basic and optional advanced stats.
          </p>
        </div>
      </div>

      <% const values=typeof formData !=='undefined' ? formData : {}; %>
        <% const errorList=Array.isArray(errors) ? errors : []; %>

          <% if (errorList.length> 0) { %>
            <div class="alert alert-danger">
              <h2 class="h6 mb-2">Please fix the following:</h2>
              <ul class="mb-0">
                <% errorList.forEach(error=> { %>
                  <li>
                    <%= error %>
                  </li>
                  <% }) %>
              </ul>
            </div>
            <% } %>

              <div class="card shadow-sm">
                <div class="card-body text-dark">
                  <form action="/matches" method="post" class="row g-3">

                    <div class="col-md-6">
                      <label for="username" class="form-label">Username</label>
                      <input type="text" class="form-control" id="username" name="username"
                        value="<%= values.username || '' %>" required>
                    </div>

                    <div class="col-md-6">
                      <label for="played_at" class="form-label">Date Played</label>
                      <input type="date" class="form-control" id="played_at" name="played_at"
                        value="<%= values.played_at || '' %>" required>
                    </div>

                    <div class="col-md-4">
                      <label for="mode" class="form-label">Mode</label>
                      <select class="form-select" id="mode" name="mode" required>
                        <option value="">Select mode</option>
                        <option value="SR" <%=values.mode==='SR' ? 'selected' : '' %>>Summoner's Rift</option>
                        <option value="ARAM" <%=values.mode==='ARAM' ? 'selected' : '' %>>ARAM</option>
                      </select>
                    </div>

                    <div class="col-md-4">
                      <label for="champion" class="form-label">Champion</label>
                      <input type="text" class="form-control" id="champion" name="champion"
                        value="<%= values.champion || '' %>" required>
                    </div>

                    <div class="col-md-4" id="roleFieldWrapper">
                      <label for="role" class="form-label">Role</label>
                      <select class="form-select" id="role" name="role">
                        <option value="">Select role</option>
                        <option value="Top" <%=values.role==='Top' ? 'selected' : '' %>>Top</option>
                        <option value="Jungle" <%=values.role==='Jungle' ? 'selected' : '' %>>Jungle</option>
                        <option value="Mid" <%=values.role==='Mid' ? 'selected' : '' %>>Mid</option>
                        <option value="ADC" <%=values.role==='ADC' ? 'selected' : '' %>>ADC</option>
                        <option value="Support" <%=values.role==='Support' ? 'selected' : '' %>>Support</option>
                      </select>
                      <div class="form-text">Role is required for Summoner's Rift and ignored for ARAM.</div>
                    </div>

                    <div class="col-md-4">
                      <label for="result" class="form-label">Result</label>
                      <select class="form-select" id="result" name="result" required>
                        <option value="">Select result</option>
                        <option value="Win" <%=values.result==='Win' ? 'selected' : '' %>>Win</option>
                        <option value="Loss" <%=values.result==='Loss' ? 'selected' : '' %>>Loss</option>
                      </select>
                    </div>

                    <div class="col-md-4">
                      <label for="kills" class="form-label">Kills</label>
                      <input type="number" min="0" class="form-control" id="kills" name="kills"
                        value="<%= values.kills || '' %>" required>
                    </div>

                    <div class="col-md-4">
                      <label for="deaths" class="form-label">Deaths</label>
                      <input type="number" min="0" class="form-control" id="deaths" name="deaths"
                        value="<%= values.deaths || '' %>" required>
                    </div>

                    <div class="col-md-4">
                      <label for="assists" class="form-label">Assists</label>
                      <input type="number" min="0" class="form-control" id="assists" name="assists"
                        value="<%= values.assists || '' %>" required>
                    </div>

                    <div class="col-12">
                      <label for="notes" class="form-label">Notes</label>
                      <textarea class="form-control" id="notes" name="notes"
                        rows="3"><%= values.notes || '' %></textarea>
                    </div>

                    <div class="col-12">
                      <details class="border rounded p-3">
                        <summary class="fw-semibold text-gold">Advanced Statistics (Optional)</summary>

                        <div class="row g-3 mt-2">
                          <div class="col-md-4">
                            <label for="game_duration" class="form-label">Game Duration (mm:ss)</label>
                            <input type="text" class="form-control" id="game_duration" name="game_duration"
                              placeholder="28:15" value="<%= values.game_duration || '' %>">
                          </div>

                          <div class="col-md-4">
                            <label for="total_gold" class="form-label">Total Gold</label>
                            <input type="number" min="0" class="form-control" id="total_gold" name="total_gold"
                              value="<%= values.total_gold || '' %>">
                          </div>

                          <div class="col-md-4">
                            <label for="total_cs" class="form-label">Total CS</label>
                            <input type="number" min="0" class="form-control" id="total_cs" name="total_cs"
                              value="<%= values.total_cs || '' %>">
                          </div>

                          <div class="col-md-4">
                            <label for="damage_dealt" class="form-label">Damage Dealt</label>
                            <input type="number" min="0" class="form-control" id="damage_dealt" name="damage_dealt"
                              value="<%= values.damage_dealt || '' %>">
                          </div>

                          <div class="col-md-4">
                            <label for="damage_taken" class="form-label">Damage Taken</label>
                            <input type="number" min="0" class="form-control" id="damage_taken" name="damage_taken"
                              value="<%= values.damage_taken || '' %>">
                          </div>

                          <div class="col-md-4">
                            <label for="vision_score" class="form-label">Vision Score</label>
                            <input type="number" min="0" class="form-control" id="vision_score" name="vision_score"
                              value="<%= values.vision_score || '' %>">
                          </div>
                        </div>
                      </details>
                    </div>

                    <div class="col-12 d-flex gap-2 justify-content-end mt-3">
                      <a href="/matches" class="btn btn-outline-dark">Cancel</a>
                      <button type="submit" class="btn btn-primary">Save Match</button>
                    </div>

                  </form>
                </div>
              </div>
    </div>
  </div>
</div>

<script>
  const modeSelect = document.getElementById('mode');
  const roleFieldWrapper = document.getElementById('roleFieldWrapper');
  const roleSelect = document.getElementById('role');
  const durationInput = document.getElementById('game_duration');
  const visionScoreInput = document.getElementById('vision_score');

  function updateRoleField() {
    if (modeSelect.value === 'ARAM') {
      roleFieldWrapper.style.display = 'none';
      roleSelect.value = '';
      roleSelect.required = false;

      if (visionScoreInput && visionScoreInput.value === '') {
        visionScoreInput.value = '0';
      }
    } else {
      roleFieldWrapper.style.display = '';
      roleSelect.required = true;
    }
  }

  function formatDurationInput() {
    if (!durationInput) return;

    let digits = durationInput.value.replace(/\D/g, '');

    if (digits.length > 4) {
      digits = digits.slice(0, 4);
    }

    if (digits.length >= 3) {
      durationInput.value = digits.slice(0, -2) + ':' + digits.slice(-2);
    } else {
      durationInput.value = digits;
    }
  }

  if (modeSelect) {
    modeSelect.addEventListener('change', updateRoleField);
    updateRoleField();
  }

  if (durationInput) {
    durationInput.addEventListener('input', formatDurationInput);
  }
</script>