<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-10">

      <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-3 mb-4">
        <div>
          <h1 class="mb-1 text-gold">
            <%= title %>
          </h1>
          <p class="text-light opacity-75 mb-0">
            View match statistics and derived performance metrics by username.
          </p>
        </div>

        <form action="/stats" method="get" class="d-flex gap-2">
          <input type="text" name="user" class="form-control" placeholder="Enter username"
            value="<%= username || '' %>" />

          <select name="range" class="form-select" style="max-width: 140px;">
            <option value="all" <%=range==='all' ? 'selected' : '' %>>All Time</option>
            <option value="20" <%=range==='20' ? 'selected' : '' %>>Last 20</option>
            <option value="10" <%=range==='10' ? 'selected' : '' %>>Last 10</option>
            <option value="5" <%=range==='5' ? 'selected' : '' %>>Last 5</option>
          </select>

          <button type="submit" class="btn btn-primary">View</button>
        </form>
      </div>

      <% if (!username) { %>
        <div class="card shadow-sm">
          <div class="card-body text-center py-5 text-dark">
            <h2 class="h5">No username selected</h2>
            <p class="text-muted mb-0">Enter a username above to view performance statistics.</p>
          </div>
        </div>

        <% } else if (!stats || stats.totalMatches===0) { %>
          <div class="card shadow-sm">
            <div class="card-body text-center py-5 text-dark">
              <h2 class="h5">No stats found</h2>
              <p class="text-muted">There are currently no recorded matches for <strong>
                  <%= username %>
                </strong>.</p>
              <a href="/matches/new" class="btn btn-primary">Add Match</a>
            </div>
          </div>

          <% } else { %>
            <p class="mb-4 text-light">
              Viewing stats for:
              <strong class="text-gold">
                <%= username %>
              </strong>

              <% if (champion) { %>
                <span class="text-light opacity-75"> • Champion:</span>
                <strong class="text-gold">
                  <%= champion %>
                </strong>
                <% } %>

                  <% if (mode) { %>
                    <span class="text-light opacity-75"> • Mode:</span>
                    <strong class="text-gold">
                      <%= mode %>
                    </strong>
                    <% } %>

                      <% if (champion || mode) { %>
                        <a href="/stats?user=<%= encodeURIComponent(username) %>&range=<%= encodeURIComponent(range) %>"
                          class="ms-2 text-light opacity-75">
                          Clear filters
                        </a>
                        <% } %>
            </p>

            <div class="row g-3 mb-4">
              <div class="col-md-3">
                <div class="card shadow-sm h-100">
                  <div class="card-body text-dark">
                    <p class="text-muted mb-1">Total Matches</p>
                    <h2 class="h4 mb-0">
                      <%= stats.totalMatches %>
                    </h2>
                  </div>
                </div>
              </div>

              <div class="col-md-3">
                <div class="card shadow-sm h-100">
                  <div class="card-body text-dark">
                    <p class="text-muted mb-1">Win Rate</p>
                    <h2 class="h4 mb-0">
                      <%= stats.winRate %>%
                    </h2>
                    <small class="text-muted">
                      <%= stats.wins %>W / <%= stats.losses %>L
                    </small>
                  </div>
                </div>
              </div>

              <div class="col-md-3">
                <div class="card shadow-sm h-100">
                  <div class="card-body text-dark">
                    <p class="text-muted mb-1">KDA</p>
                    <h2 class="h4 mb-0">
                      <%= stats.averageKills %> / <%= stats.averageDeaths %> / <%= stats.averageAssists %>
                    </h2>
                  </div>
                </div>
              </div>

              <div class="col-md-3">
                <div class="card shadow-sm h-100">
                  <div class="card-body text-dark">
                    <p class="text-muted mb-1">Average Stats</p>
                    <h2 class="h6 mb-1">
                      GPM:
                      <%= stats.averageGpm !==null ? Number(stats.averageGpm).toLocaleString(undefined, {
                        maximumFractionDigits: 0 }) : '-' %>
                    </h2>
                    <h2 class="h6 mb-1">CSM: <%= stats.averageCsm ?? '-' %>
                    </h2>
                    <h2 class="h6 mb-1">
                      Damage Dealt:
                      <%= stats.averageDamageDealt !==null ? stats.averageDamageDealt.toLocaleString() : '-' %>
                    </h2>
                    <h2 class="h6 mb-0">
                      Damage Taken:
                      <%= stats.averageDamageTaken !==null ? stats.averageDamageTaken.toLocaleString() : '-' %>
                    </h2>
                  </div>
                </div>
              </div>
            </div>

            <div class="row g-4">
              <div class="col-lg-6">
                <div class="card shadow-sm h-100">
                  <div class="card-body text-dark">
                    <h2 class="h5 mb-3 text-gold">Matches by Mode</h2>

                    <% const modeEntries=Object.entries(stats.modeStats || {}); %>

                      <% if (modeEntries.length===0) { %>
                        <p class="text-muted mb-0">No mode data available.</p>
                        <% } else { %>
                          <ul class="list-group list-group-flush">
                            <% modeEntries.forEach(([mode, data])=> {
                              const winRate = data.total > 0
                              ? Math.round((data.wins / data.total) * 100)
                              : 0;
                              %>
                              <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span>
                                  <a href="/stats?user=<%= encodeURIComponent(username) %>&mode=<%= encodeURIComponent(mode) %>&range=<%= encodeURIComponent(range) %>"
                                    class="text-decoration-none text-dark fw-semibold">
                                    <%= mode %>
                                  </a>
                                  <br>
                                  <small class="text-muted">
                                    <%= data.wins %>W / <%= data.total - data.wins %>L • <%= winRate %>%
                                  </small>
                                  <div>
                                    <a href="/matches?user=<%= encodeURIComponent(username) %>&mode=<%= encodeURIComponent(mode) %>"
                                      class="small text-muted">
                                      View matches
                                    </a>
                                  </div>
                                </span>
                                <span class="badge bg-dark px-2 py-1">
                                  <%= data.total %>
                                </span>
                              </li>
                              <% }) %>
                          </ul>
                          <% } %>
                  </div>
                </div>
              </div>

              <div class="col-lg-6">
                <div class="card shadow-sm h-100">
                  <div class="card-body text-dark">
                    <h2 class="h5 mb-3 text-gold">Most Played Champions</h2>

                    <% if (!stats.mostPlayedChampions || stats.mostPlayedChampions.length===0) { %>
                      <p class="text-muted mb-0">No champion data available.</p>
                      <% } else { %>
                        <ul class="list-group list-group-flush">
                          <% stats.mostPlayedChampions.slice(0, 5).forEach(item=> { %>
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                              <div>
                                <a href="/stats?user=<%= encodeURIComponent(username) %>&champion=<%= encodeURIComponent(item.champion) %>&range=<%= encodeURIComponent(range) %>"
                                  class="text-decoration-none text-dark fw-semibold">
                                  <%= item.champion %>
                                </a>

                                <div>
                                  <a href="/matches?user=<%= encodeURIComponent(username) %>&champion=<%= encodeURIComponent(item.champion) %>"
                                    class="small text-muted">
                                    View matches
                                  </a>
                                </div>
                              </div>

                              <span class="badge bg-dark px-2 py-1">
                                <%= item.count %>
                              </span>
                            </li>
                            <% }) %>
                        </ul>
                        <% } %>
                  </div>
                </div>
              </div>
            </div>

            <div class="card shadow-sm mt-4">
              <div class="card-body p-0 text-dark">
                <div class="p-3 border-bottom">
                  <h2 class="h5 mb-0 text-gold">Recent Matches</h2>
                </div>

                <div class="table-responsive">
                  <table class="table table-striped table-hover align-middle mb-0">
                    <thead class="table-light">
                      <tr>
                        <th>Date</th>
                        <th>Mode</th>
                        <th>Champion</th>
                        <th>Result</th>
                        <th>K / D / A</th>
                        <th>View</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% stats.recentMatches.forEach(match=> { %>
                        <tr>
                          <td>
                            <%= match.played_at %>
                          </td>
                          <td>
                            <%= match.mode %>
                          </td>
                          <td>
                            <%= match.champion %>
                          </td>
                          <td>
                            <span class="badge <%= match.result === 'Win' ? 'bg-success' : 'bg-danger' %>">
                              <%= match.result %>
                            </span>
                          </td>
                          <td>
                            <%= match.kills %> / <%= match.deaths %> / <%= match.assists %>
                          </td>
                          <td>
                            <a href="/matches/<%= match.id %>" class="btn btn-sm btn-outline-primary">View</a>
                          </td>
                        </tr>
                        <% }) %>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>

            <% } %>

    </div>
  </div>
</div>